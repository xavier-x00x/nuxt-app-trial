<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              name="invoice"
              pageWidth="595" pageHeight="842"
              columnWidth="535"
              leftMargin="30" rightMargin="30"
              topMargin="30" bottomMargin="30">

  <parameter name="companyName" class="java.lang.String"/>
  <parameter name="tagline" class="java.lang.String"/>
  <parameter name="invoiceNo" class="java.lang.String"/>
  <parameter name="invoiceDate" class="java.lang.String"/>
  <parameter name="billToName" class="java.lang.String"/>
  <parameter name="billToAddress" class="java.lang.String"/>
  <parameter name="logoPath" class="java.lang.String"/>

  <field name="st" class="java.lang.Integer"/>
  <field name="description" class="java.lang.String"/>
  <field name="rate" class="java.math.BigDecimal"/>
  <field name="hours" class="java.math.BigDecimal"/>
  <field name="price" class="java.math.BigDecimal"/>

  <variable name="grandTotal" class="java.math.BigDecimal" calculation="Sum" resetType="Report">
    <variableExpression>$F{price}</variableExpression>
  </variable>

  <title>
    <band height="160" splitType="Stretch">
      <rectangle>
        <reportElement x="0" y="0" width="535" height="80" mode="Opaque" backcolor="#F1F5F9"/>
        <graphicElement>
          <pen lineWidth="0" lineColor="#F1F5F9"/>
        </graphicElement>
      </rectangle>
      <rectangle>
        <reportElement x="380" y="0" width="155" height="80" mode="Opaque" backcolor="#2563EB"/>
        <graphicElement>
          <pen lineWidth="0" lineColor="#2563EB"/>
        </graphicElement>
      </rectangle>

      <image scaleImage="RetainShape" hAlign="Left" vAlign="Middle">
        <reportElement x="20" y="20" width="46" height="46"/>
        <imageExpression><![CDATA[$P{logoPath}]]></imageExpression>
      </image>

      <staticText>
        <reportElement x="80" y="22" width="200" height="22"/>
        <textElement>
          <font fontName="SansSerif" size="16" isBold="true"/>
        </textElement>
        <text><![CDATA[COMPANY]]></text>
      </staticText>
      <staticText>
        <reportElement x="80" y="44" width="200" height="20"/>
        <textElement>
          <font fontName="SansSerif" size="16" isBold="true"/>
        </textElement>
        <text><![CDATA[NAME]]></text>
      </staticText>

      <staticText>
        <reportElement x="300" y="20" width="80" height="14" forecolor="#475569"/>
        <textElement textAlignment="Left">
          <font fontName="SansSerif" size="9"/>
        </textElement>
        <text><![CDATA[INVOICE NO.:]]></text>
      </staticText>
      <textField isBlankWhenNull="true">
        <reportElement x="200" y="20" width="180" height="14" forecolor="#0F172A"/>
        <textElement textAlignment="Right">
          <font fontName="SansSerif" size="10" isBold="true"/>
        </textElement>
        <textFieldExpression><![CDATA["000 " + $P{invoiceNo}]]></textFieldExpression>
      </textField>

      <staticText>
        <reportElement x="200" y="38" width="40" height="14" forecolor="#0F172A"/>
        <textElement textAlignment="Left">
          <font fontName="SansSerif" size="9" isBold="true"/>
        </textElement>
        <text><![CDATA[Date:]]></text>
      </staticText>
      <textField isBlankWhenNull="true">
        <reportElement x="240" y="38" width="140" height="14" forecolor="#0F172A"/>
        <textElement textAlignment="Left">
          <font fontName="SansSerif" size="9"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{invoiceDate}]]></textFieldExpression>
      </textField>

      <frame>
        <reportElement x="0" y="90" width="280" height="60" mode="Opaque" backcolor="#2563EB"/>
        <box>
          <pen lineWidth="0" lineColor="#2563EB"/>
        </box>
        <staticText>
          <reportElement x="14" y="8" width="200" height="14" forecolor="#FFFFFF"/>
          <textElement textAlignment="Left">
            <font fontName="SansSerif" size="9" isBold="true"/>
          </textElement>
          <text><![CDATA[INVOICE TO:]]></text>
        </staticText>
        <textField isBlankWhenNull="true">
          <reportElement x="14" y="22" width="252" height="14" forecolor="#FFFFFF"/>
          <textElement textAlignment="Left">
            <font fontName="SansSerif" size="10" isBold="true"/>
          </textElement>
          <textFieldExpression><![CDATA[$P{billToName}]]></textFieldExpression>
        </textField>
        <textField isStretchWithOverflow="true" isBlankWhenNull="true">
          <reportElement x="14" y="36" width="252" height="22" forecolor="#E0E7FF"/>
          <textElement textAlignment="Left">
            <font fontName="SansSerif" size="8"/>
          </textElement>
          <textFieldExpression><![CDATA[$P{billToAddress}]]></textFieldExpression>
        </textField>
      </frame>
    </band>
  </title>

  <columnHeader>
    <band height="40" splitType="Stretch">
      <staticText>
        <reportElement x="0" y="10" width="40" height="20" forecolor="#0F172A"/>
        <textElement textAlignment="Center">
          <font fontName="SansSerif" size="10" isBold="true"/>
        </textElement>
        <text><![CDATA[St.]]></text>
      </staticText>
      <staticText>
        <reportElement x="40" y="10" width="220" height="20" forecolor="#0F172A"/>
        <textElement textAlignment="Left">
          <font fontName="SansSerif" size="10" isBold="true"/>
        </textElement>
        <text><![CDATA[Item Description]]></text>
      </staticText>
      <staticText>
        <reportElement x="260" y="10" width="80" height="20" forecolor="#0F172A"/>
        <textElement textAlignment="Center">
          <font fontName="SansSerif" size="10" isBold="true"/>
        </textElement>
        <text><![CDATA[Rate]]></text>
      </staticText>
      <staticText>
        <reportElement x="340" y="10" width="80" height="20" forecolor="#0F172A"/>
        <textElement textAlignment="Center">
          <font fontName="SansSerif" size="10" isBold="true"/>
        </textElement>
        <text><![CDATA[Hours]]></text>
      </staticText>
      <staticText>
        <reportElement x="420" y="10" width="115" height="20" forecolor="#0F172A"/>
        <textElement textAlignment="Right">
          <font fontName="SansSerif" size="10" isBold="true"/>
        </textElement>
        <text><![CDATA[Price]]></text>
      </staticText>
    </band>
  </columnHeader>

  <detail>
    <band height="36" splitType="Prevent">
      <rectangle>
        <reportElement x="0" y="0" width="535" height="36" mode="Opaque" backcolor="#F5F7FA"
                       printWhenExpression="$V{REPORT_COUNT} % 2 == 0"/>
        <graphicElement>
          <pen lineWidth="0" lineColor="#F5F7FA"/>
        </graphicElement>
      </rectangle>
      <textField>
        <reportElement x="0" y="8" width="40" height="20" forecolor="#0F172A"/>
        <textElement textAlignment="Center">
          <font fontName="SansSerif" size="10"/>
        </textElement>
        <textFieldExpression><![CDATA[$F{st}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="40" y="8" width="220" height="20" forecolor="#0F172A"/>
        <textElement textAlignment="Left">
          <font fontName="SansSerif" size="10"/>
        </textElement>
        <textFieldExpression><![CDATA[$F{description}]]></textFieldExpression>
      </textField>
      <textField pattern="#,##0.00">
        <reportElement x="260" y="8" width="80" height="20" forecolor="#0F172A"/>
        <textElement textAlignment="Center">
          <font fontName="SansSerif" size="10"/>
        </textElement>
        <textFieldExpression><![CDATA["$" + $F{rate}]]></textFieldExpression>
      </textField>
      <textField pattern="#,##0">
        <reportElement x="340" y="8" width="80" height="20" forecolor="#0F172A"/>
        <textElement textAlignment="Center">
          <font fontName="SansSerif" size="10"/>
        </textElement>
        <textFieldExpression><![CDATA[$F{hours}]]></textFieldExpression>
      </textField>
      <textField pattern="#,##0">
        <reportElement x="420" y="8" width="115" height="20" forecolor="#0F172A"/>
        <textElement textAlignment="Right">
          <font fontName="SansSerif" size="10"/>
        </textElement>
        <textFieldExpression><![CDATA["$" + $F{price}]]></textFieldExpression>
      </textField>
    </band>
  </detail>

  <columnFooter>
    <band height="44" splitType="Stretch">
      <line>
        <reportElement x="0" y="6" width="535" height="1"/>
        <graphicElement>
          <pen lineWidth="0.5" lineColor="#CBD5E1"/>
        </graphicElement>
      </line>
      <staticText>
        <reportElement x="260" y="14" width="160" height="22" forecolor="#0F172A"/>
        <textElement textAlignment="Right">
          <font fontName="SansSerif" size="12" isBold="true"/>
        </textElement>
        <text><![CDATA[TOTAL]]></text>
      </staticText>
      <textField pattern="#,##0.00">
        <reportElement x="420" y="14" width="115" height="22" forecolor="#0F172A"/>
        <textElement textAlignment="Right">
          <font fontName="SansSerif" size="12" isBold="true"/>
        </textElement>
        <textFieldExpression><![CDATA["$" + $V{grandTotal}]]></textFieldExpression>
      </textField>
    </band>
  </columnFooter>

  <summary>
    <band height="100" splitType="Stretch">
      <componentElement>
        <reportElement x="0" y="20" width="80" height="80"/>
        <jr:barbecue xmlns:jr="http://jasperreports.sourceforge.net/jasperreports/components" type="qrcode">
          <jr:codeExpression><![CDATA["INV-" + $P{invoiceNo} + "/" + $P{billToName}]]></jr:codeExpression>
        </jr:barbecue>
      </componentElement>
      <staticText>
        <reportElement x="100" y="30" width="200" height="14" forecolor="#0F172A"/>
        <textElement>
          <font fontName="SansSerif" size="10" isBold="true"/>
        </textElement>
        <text><![CDATA[Scan to verify invoice]]></text>
      </staticText>
      <staticText>
        <reportElement x="100" y="48" width="400" height="40" forecolor="#64748B"/>
        <textElement>
          <font fontName="SansSerif" size="9"/>
        </textElement>
        <text><![CDATA[Payment is due within 30 days. Please reference the invoice number when making payment via bank transfer.]]></text>
      </staticText>
    </band>
  </summary>

  <pageFooter>
    <band height="30" splitType="Stretch">
      <staticText>
        <reportElement x="0" y="10" width="300" height="14" forecolor="#64748B"/>
        <textElement textAlignment="Left">
          <font fontName="SansSerif" size="9"/>
        </textElement>
        <text><![CDATA[Thank you for your business.]]></text>
      </staticText>
      <textField>
        <reportElement x="335" y="10" width="200" height="14" forecolor="#64748B"/>
        <textElement textAlignment="Right">
          <font fontName="SansSerif" size="9"/>
        </textElement>
        <textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER} + " of " + $V{PAGE_COUNT}]]></textFieldExpression>
      </textField>
    </band>
  </pageFooter>

</jasperReport>
