<?xml version="1.0" encoding="UTF-8"?>
<jasperReport name="ProductSpecificationReport" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
  <!-- Title Band containing corporate header and metadata -->
  <title>
    <band height="200">
      <!-- Gray backdrop polygon panel representation -->
      <rectangle>
        <reportElement x="0" y="0" width="310" height="200" backcolor="#e2e8f0" mode="Opaque" />
        <pen lineWidth="0" />
      </rectangle>
      
      <!-- Top-right blue accent stripe -->
      <rectangle>
        <reportElement x="310" y="0" width="245" height="30" backcolor="#3b82f6" mode="Opaque" />
        <pen lineWidth="0" />
      </rectangle>

      <!-- Logo design: Pills and dot -->
      <ellipse>
        <reportElement x="32" y="24" width="8" height="8" backcolor="#2563eb" mode="Opaque" />
      </ellipse>
      <rectangle>
        <reportElement x="12" y="38" width="8" height="26" backcolor="#2563eb" mode="Opaque" />
        <pen lineWidth="0" />
      </rectangle>
      <rectangle>
        <reportElement x="22" y="28" width="8" height="36" backcolor="#2563eb" mode="Opaque" />
        <pen lineWidth="0" />
      </rectangle>

      <!-- Logo Text -->
      <staticText>
        <reportElement x="65" y="24" width="180" height="22" />
        <textElement textAlignment="Left" verticalAlignment="Middle" />
        <font fontName="Helvetica" size="16" isBold="true" />
        <text><![CDATA[COMPANY]]></text>
      </staticText>
      <staticText>
        <reportElement x="65" y="44" width="180" height="22" />
        <textElement textAlignment="Left" verticalAlignment="Middle" />
        <font fontName="Helvetica" size="16" isBold="true" />
        <text><![CDATA[NAME]]></text>
      </staticText>

      <!-- Invoice/Report Metadata -->
      <textField>
        <reportElement x="320" y="15" width="220" height="25" />
        <textElement textAlignment="Right" verticalAlignment="Middle" />
        <font fontName="Helvetica" size="11" isBold="true" />
        <textFieldExpression><![CDATA["INVOICE NO.: 000 " + $F{productId}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="320" y="38" width="220" height="20" />
        <textElement textAlignment="Right" verticalAlignment="Middle" />
        <font fontName="Helvetica" size="8" />
        <textFieldExpression><![CDATA["Date: " + $F{createdAt}]]></textFieldExpression>
      </textField>

      <!-- Specification Info Box -->
      <rectangle>
        <reportElement x="320" y="65" width="220" height="100" backcolor="#ffffff" mode="Opaque" />
        <pen lineWidth="0.5" />
      </rectangle>
      
      <staticText>
        <reportElement x="330" y="75" width="200" height="15" />
        <textElement textAlignment="Left" verticalAlignment="Middle" />
        <font fontName="Helvetica" size="8" isBold="true" />
        <text><![CDATA[PRODUCT SPECIFICATION]]></text>
      </staticText>
      <textField>
        <reportElement x="330" y="92" width="200" height="20" />
        <textElement textAlignment="Left" verticalAlignment="Middle" />
        <font fontName="Helvetica" size="10" isBold="true" />
        <textFieldExpression><![CDATA[$F{productName}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="330" y="114" width="200" height="15" />
        <textElement textAlignment="Left" verticalAlignment="Middle" />
        <font fontName="Helvetica" size="8" />
        <textFieldExpression><![CDATA["SKU: " + $F{productSku}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="330" y="131" width="200" height="15" />
        <textElement textAlignment="Left" verticalAlignment="Middle" />
        <font fontName="Helvetica" size="8" />
        <textFieldExpression><![CDATA["Category: " + $F{categoryName}]]></textFieldExpression>
      </textField>
    </band>
  </title>

  <!-- Column Header Band for table column titles -->
  <columnHeader>
    <band height="35">
      <staticText>
        <reportElement x="0" y="5" width="40" height="25" />
        <textElement textAlignment="Center" verticalAlignment="Middle" />
        <font fontName="Helvetica" size="10" isBold="true" />
        <text><![CDATA[St.]]></text>
      </staticText>
      <staticText>
        <reportElement x="50" y="5" width="220" height="25" />
        <textElement textAlignment="Left" verticalAlignment="Middle" />
        <font fontName="Helvetica" size="10" isBold="true" />
        <text><![CDATA[Item Description]]></text>
      </staticText>
      <staticText>
        <reportElement x="280" y="5" width="90" height="25" />
        <textElement textAlignment="Center" verticalAlignment="Middle" />
        <font fontName="Helvetica" size="10" isBold="true" />
        <text><![CDATA[Group]]></text>
      </staticText>
      <staticText>
        <reportElement x="380" y="5" width="60" height="25" />
        <textElement textAlignment="Center" verticalAlignment="Middle" />
        <font fontName="Helvetica" size="10" isBold="true" />
        <text><![CDATA[Unit]]></text>
      </staticText>
      <staticText>
        <reportElement x="450" y="5" width="105" height="25" />
        <textElement textAlignment="Right" verticalAlignment="Middle" />
        <font fontName="Helvetica" size="10" isBold="true" />
        <text><![CDATA[Value]]></text>
      </staticText>
      <line>
        <reportElement x="0" y="32" width="555" height="1" />
      </line>
    </band>
  </columnHeader>

  <!-- Detail Band repeating for each specification item -->
  <detail>
    <band height="35">
      <textField>
        <reportElement x="0" y="5" width="40" height="25" />
        <textElement textAlignment="Center" verticalAlignment="Middle" />
        <font fontName="Helvetica" size="9" />
        <textFieldExpression><![CDATA[$V{REPORT_COUNT}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="50" y="5" width="220" height="25" />
        <textElement textAlignment="Left" verticalAlignment="Middle" />
        <font fontName="Helvetica" size="9" isBold="true" />
        <textFieldExpression><![CDATA[$F{label}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="280" y="5" width="90" height="25" />
        <textElement textAlignment="Center" verticalAlignment="Middle" />
        <font fontName="Helvetica" size="9" />
        <textFieldExpression><![CDATA[$F{group}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="380" y="5" width="60" height="25" />
        <textElement textAlignment="Center" verticalAlignment="Middle" />
        <font fontName="Helvetica" size="9" />
        <textFieldExpression><![CDATA[$F{unit}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="450" y="5" width="105" height="25" />
        <textElement textAlignment="Right" verticalAlignment="Middle" />
        <font fontName="Helvetica" size="9" isBold="true" />
        <textFieldExpression><![CDATA[$F{value}]]></textFieldExpression>
      </textField>
    </band>
  </detail>

  <!-- Page Footer Band absolutely anchored at bottom of pages -->
  <pageFooter>
    <band height="40">
      <line>
        <reportElement x="0" y="5" width="555" height="1" />
      </line>
      <staticText>
        <reportElement x="0" y="15" width="250" height="20" />
        <textElement textAlignment="Left" verticalAlignment="Middle" />
        <font fontName="Helvetica" size="8" />
        <text><![CDATA[Generated dynamically via JRXML Web Engine]]></text>
      </staticText>
      <staticText>
        <reportElement x="350" y="15" width="205" height="20" />
        <textElement textAlignment="Right" verticalAlignment="Middle" />
        <font fontName="Helvetica" size="9" isBold="true" />
        <text><![CDATA[AUTHORIZED REPORT]]></text>
      </staticText>
    </band>
  </pageFooter>
</jasperReport>
